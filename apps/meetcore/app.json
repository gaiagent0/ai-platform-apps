{
  "name": "meetcore",
  "version": "2.0.0",
  "type": "docker",
  "description": "Meeting hangrögzítés és AI összefoglaló. GenieX SDK, Parakeet ASR, 8 provider, Piper TTS",
  "status": "active",
  "repository": "https://github.com/gaiagent0/meetcore",
  "ports": [3118, 5167],
  "default_port": 3118,
  "compose_file": "docker-compose.yml",
  "health_endpoint": "/health",
  "dependencies": ["litellm", "langfuse"],
  "models": [
    {
      "name": "whisper",
      "source": "huggingface",
      "path": "base"
    },
    {
      "name": "parakeet",
      "source": "nexa",
      "path": "parakeet-tdt-0.6b-v3-npu"
    }
  ],
  "environment": {
    "GENIEX_BASE_URL": "http://host.docker.internal:8912/v1",
    "GENIEX_MODEL": "llama3.1-8b-qat",
    "WHISPER_LANGUAGE": "hu",
    "BACKEND_PORT": "5167",
    "LITELLM_BASE_URL": "http://host.docker.internal:4001"
  }
}
