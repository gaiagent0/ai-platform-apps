# MeetCore Environment Configuration

# Backend
BACKEND_PORT=5167

# GenieX SDK (OpenAI-compatible NPU inference)
GENIEX_BASE_URL=http://host.docker.internal:8912/v1
GENIEX_MODEL=llama3.1-8b-qat

# LiteLLM Gateway (cloud LLMs)
LITELLM_BASE_URL=http://host.docker.internal:4001
LITELLM_API_KEY=

# ASR (Speech-to-Text)
WHISPER_LANGUAGE=hu
WHISPER_MODEL_SIZE=base

# TTS (Text-to-Speech)
PIPER_VOICE=hu_HU-dfpros-medium

# Langfuse Tracing
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://10.10.40.36:3000

# MCP Server
MCP_PORT=8007
